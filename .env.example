# ============================================================
#  TechFix — Variables de Entorno (Plantilla)
#  Copia este archivo como `.env` y ajusta las contraseñas
# ============================================================

# ── Usuarios / Roles DB ───────────────────────────────────────
USUARIOS_DB_HOST=postgres_usuarios
USUARIOS_DB_PORT=5432
USUARIOS_DB_NAME=techfix_usuarios
USUARIOS_DB_USER=techfix_usr
USUARIOS_DB_PASSWORD=TU_PASSWORD_AQUI

# ── Pagos DB ──────────────────────────────────────────────────
PAGOS_DB_HOST=postgres_pagos
PAGOS_DB_PORT=5432
PAGOS_DB_NAME=techfix_payment
PAGOS_DB_USER=techfix_pay
PAGOS_DB_PASSWORD=TU_PASSWORD_AQUI

# ── Stock / Repuestos DB ──────────────────────────────────────
STOCK_DB_HOST=postgres_stock
STOCK_DB_PORT=5432
STOCK_DB_NAME=techfix_stock
STOCK_DB_USER=techfix_stock
STOCK_DB_PASSWORD=TU_PASSWORD_AQUI

# ── Agenda / Citas DB ─────────────────────────────────────────
AGENDA_DB_HOST=postgres_agenda
AGENDA_DB_PORT=5432
AGENDA_DB_NAME=techfix_agenda
AGENDA_DB_USER=techfix_agenda
AGENDA_DB_PASSWORD=TU_PASSWORD_AQUI

# ── API Gateway ───────────────────────────────────────────────
GATEWAY_PORT=8090
